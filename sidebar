:root {
  --navy: #1e3a5f;
  --slate: #334155;
  --bg: radial-gradient(circle, #ffffff 0%, #e0f2fe 100%);
}

body {
  margin: 0;
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  background-attachment: fixed;
  min-height: 100vh;
}

.main-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px 40px;
  background: rgba(255, 255, 255, 0.8);
}

.logo {
  font-weight: 800;
  font-size: 0.85rem;
  color: var(--navy);
  line-height: 1.1;
}

.center-nav a {
  text-decoration: none;
  color: #64748b;
  margin: 0 15px;
  font-size: 0.85rem;
  font-weight: 600;
}

.user-profile-mini {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.85rem;
  font-weight: 700;
}

.dashboard-wrapper {
  display: flex;
  padding: 20px 40px;
  gap: 25px;
  align-items: flex-start;
}

/* Sidebar */
.sidebar {
  width: 220px;
  background: white;
  border-radius: 15px;
  padding: 20px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  text-decoration: none;
  color: #1e293b;
  font-size: 0.85rem;
  font-weight: 600;
  border-radius: 8px;
  margin-bottom: 4px;
}

.nav-item.active {
  background: var(--navy);
  color: white;
}

.logout-bottom {
  margin-top: 40px;
  border-top: 1px solid #e2e8f0;
  padding-top: 20px;
}

/* Main Content */
.main-panel {
  flex: 1;
}

.header-text h1 {
  font-size: 1.6rem;
  font-weight: 800;
  margin: 5px 0;
}
